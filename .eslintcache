ondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\helper\\query.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\pages\\blog\\section-content.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\pages\\blog\\section-profile.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\components\\s-item_holder\\s-item_holder-container.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\components\\p-item_holder\\p-item_holder-container.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\components\\blog-post_holder\\blog-post_holder-container.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\components\\blog-post_holder\\blog-post_holder.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\firebase\\config.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\animation\\_smooth-scroll.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\animation\\blog-animation\\blog-animation.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\hooks\\scroll-listener.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\hooks\\empty-object.js",["157"],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\hooks\\scroll-position.js",["158"],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\hooks\\wait-for-element.js",["159"],"import { useEffect, useState } from 'react';\r\n\r\nconst useWaitForElm = (selector) => {\r\n    const [isElementExist, setIsElementExist] = useState();\r\n    const [element, setElement] = useState();\r\n\r\n    const waitForElm = (selector) => {\r\n        return new Promise(resolve => {\r\n            if (document.querySelector(selector)) {\r\n                return resolve(document.querySelector(selector));\r\n            }\r\n    \r\n            const observer = new MutationObserver(mutations => {\r\n                if (document.querySelector(selector)) {\r\n                    resolve(document.querySelector(selector));\r\n                    observer.disconnect();\r\n                }\r\n            });\r\n    \r\n            observer.observe(document.body, {\r\n                childList: true,\r\n                subtree: true\r\n            });\r\n        });\r\n    } // create an observer for the dom if a new element exist\r\n\r\n    const data = async() => {\r\n        try{\r\n            let dataElm = await waitForElm(selector);\r\n            if(dataElm){\r\n                setElement(dataElm);\r\n                setIsElementExist(true);\r\n            }else{\r\n                setElement('');\r\n                setIsElementExist(false);\r\n            }\r\n        }catch( err ){\r\n            console.log(err.response.data.message)\r\n        }\r\n    } // call the created observer method and set the use state\r\n\r\n    \r\n    useEffect(() => {\r\n        data();\r\n\r\n    }, [element, isElementExist]) //add element and isElementExist dependencies if you want to log the data\r\n\r\n    return [element, isElementExist];\r\n}\r\n\r\n//source: https://stackoverflow.com/questions/5525071/how-to-wait-until-an-element-exists\r\nexport {useWaitForElm};",["160","161"],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\components\\modal-email\\modal-email-container.js",["162"],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\components\\modal-email\\modal-email.js",[],"C:\\Users\\Mark Albert Makondo\\Desktop\\Global Projects\\Portfolio-v3\\src\\pages\\blog\\section-profile-container.js",[],{"ruleId":"163","severity":1,"message":"164","line":22,"column":8,"nodeType":"165","endLine":22,"endColumn":10,"suggestions":"166"},{"ruleId":"163","severity":1,"message":"167","l